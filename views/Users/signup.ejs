<% layout("/layouts/boilerplate")%>
<style>
    .auth-page {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        padding: 2.5rem 1rem 4rem;
        position: relative;
    }

    .auth-page::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 20%, rgba(124,58,237,0.07) 0%, transparent 60%);
        pointer-events: none;
    }

    .auth-card { width: 100%; max-width: 560px; position: relative; z-index: 1; }

    .auth-brand { text-align: center; margin-bottom: 2rem; }

    .auth-brand-mark {
        width: 52px; height: 52px;
        background: linear-gradient(135deg, #7c3aed, #06b6d4);
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1rem;
        box-shadow: 0 0 24px rgba(124,58,237,0.4);
    }

    .auth-brand h1 {
        font-family: 'Outfit', sans-serif;
        font-size: 1.5rem; font-weight: 800; color: var(--text); letter-spacing: -0.5px; margin-bottom: 0.3rem;
    }
    .auth-brand p { font-size: 0.85rem; color: var(--text-muted); }

    .auth-form-card {
        background: var(--surface);
        border: 1px solid rgba(124,58,237,0.15);
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 1rem;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }

    .auth-section { padding: 1.25rem 1.5rem; }
    .auth-section + .auth-section { border-top: 1px solid var(--border); }

    .auth-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--primary-light);
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .form-row-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    .form-field { margin-bottom: 0.9rem; }
    .form-field:last-child { margin-bottom: 0; }

    .form-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 0.3rem;
    }

    .opt {
        color: var(--text-dim);
        font-weight: 400;
        font-size: 0.7rem;
        margin-left: 4px;
    }

    .form-control {
        width: 100%;
        background: var(--surface-2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 0.55rem 0.85rem;
        color: var(--text);
        font-size: 0.88rem;
        font-family: var(--font);
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-glow);
    }

    .form-control::placeholder { color: var(--text-dim); }

    .pass-wrap { position: relative; }
    .pass-toggle {
        position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%);
        background: none; border: none; color: var(--text-dim); cursor: pointer;
        padding: 0; font-size: 0.875rem; transition: color 0.15s;
    }
    .pass-toggle:hover { color: var(--primary-light); }

    .branch-tip {
        font-size: 0.72rem;
        color: var(--text-dim);
        margin-top: 0.25rem;
        transition: color 0.2s;
    }

    .auth-submit {
        width: 100%;
        justify-content: center;
        padding: 0.72rem 1rem;
        font-size: 0.9rem;
    }

    .auth-alt { text-align: center; font-size: 0.83rem; color: var(--text-muted); }
    .auth-alt a { color: var(--primary-light); font-weight: 600; text-decoration: none; }
    .auth-alt a:hover { text-decoration: underline; }

    @media (max-width: 480px) {
        .form-row-2 { grid-template-columns: 1fr; }
    }
</style>

<div class="auth-page">
<div class="auth-card">
    <div class="auth-brand">
        <div class="auth-brand-mark">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L2 7l10 5 10-5-10-5z" fill="white" opacity="0.9"/>
                <path d="M2 17l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" fill="none" opacity="0.7"/>
                <path d="M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" fill="none"/>
            </svg>
        </div>
        <h1>Join Campus Connect</h1>
        <p>Create your free student account</p>
    </div>

    <div class="auth-form-card">
        <form action="/signup" method="POST">

            <!-- Account -->
            <div class="auth-section">
                <div class="auth-section-title"><i class="fas fa-lock"></i> Account Details</div>
                <div class="form-row-2">
                    <div class="form-field">
                        <label for="username" class="form-label">Username</label>
                        <input type="text" name="username" id="username" class="form-control" required
                            placeholder="e.g. prince_yadav" autocomplete="username" maxlength="30">
                    </div>
                    <div class="form-field">
                        <label for="email" class="form-label">College Email</label>
                        <input type="email" name="email" id="email" class="form-control" required
                            placeholder="you@college.edu.in" autocomplete="email">
                    </div>
                </div>
                <div class="form-field">
                    <label for="password" class="form-label">Password</label>
                    <div class="pass-wrap">
                        <input type="password" name="password" id="password" class="form-control" required
                            placeholder="Minimum 6 characters" autocomplete="new-password" minlength="6"
                            style="padding-right:2.5rem;">
                        <button type="button" class="pass-toggle" onclick="togglePass('password', this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Academic -->
            <div class="auth-section">
                <div class="auth-section-title"><i class="fas fa-graduation-cap"></i> Academic Info</div>
                <div class="form-field">
                    <label for="fullName" class="form-label">Full Name</label>
                    <input type="text" name="fullName" id="fullName" class="form-control"
                        placeholder="As per college ID card" required>
                </div>
                <div class="form-row-2">
                    <div class="form-field">
                        <label for="branch" class="form-label">Branch / Programme</label>
                        <select name="branch" id="branch" class="form-control" required>
                            <option value="">Select branch</option>
                            <option value="CSE">B.Tech — CSE</option>
                            <option value="ECE">B.Tech — ECE</option>
                            <option value="IT">B.Tech — IT</option>
                            <option value="MBA">MBA</option>
                            <option value="Other">Other</option>
                        </select>
                        <div class="branch-tip" id="branch-tip">All departments welcome on Campus Connect.</div>
                    </div>
                    <div class="form-field">
                        <label for="year" class="form-label">Year of Study</label>
                        <select name="year" id="year" class="form-control" required>
                            <option value="">Select year</option>
                            <option value="1">1st Year</option>
                            <option value="2">2nd Year</option>
                            <option value="3">3rd Year</option>
                            <option value="4">4th Year / Final</option>
                        </select>
                    </div>
                </div>
                <div class="form-field">
                    <label for="enrollmentNo" class="form-label">Enrollment Number</label>
                    <input type="text" name="enrollmentNo" id="enrollmentNo" class="form-control"
                        placeholder="e.g. 22SCSE1010123" required maxlength="20">
                </div>
            </div>

            <!-- Social + Skills -->
            <div class="auth-section">
                <div class="auth-section-title"><i class="fas fa-link"></i> Profile Links <span style="text-transform:none;letter-spacing:0;font-weight:400;color:var(--text-dim);font-family:var(--font);">(optional)</span></div>
                <div class="form-row-2">
                    <div class="form-field">
                        <label for="github" class="form-label"><i class="fab fa-github" style="color:var(--text-dim)"></i> GitHub URL</label>
                        <input type="url" name="github" id="github" class="form-control"
                            placeholder="https://github.com/you">
                    </div>
                    <div class="form-field">
                        <label for="linkedin" class="form-label"><i class="fab fa-linkedin" style="color:var(--text-dim)"></i> LinkedIn URL</label>
                        <input type="url" name="linkedin" id="linkedin" class="form-control"
                            placeholder="https://linkedin.com/in/you">
                    </div>
                </div>
                <div class="form-field">
                    <label for="skills" class="form-label">Skills <span class="opt">comma separated</span></label>
                    <input type="text" name="skills" id="skills" class="form-control"
                        placeholder="e.g. JavaScript, Python, DSA, React">
                </div>
            </div>

            <!-- About -->
            <div class="auth-section">
                <div class="auth-section-title"><i class="fas fa-user"></i> About You <span style="text-transform:none;letter-spacing:0;font-weight:400;color:var(--text-dim);font-family:var(--font);">(optional)</span></div>
                <div class="form-field">
                    <label for="bio" class="form-label">Short Bio <span class="opt">max 300 chars</span></label>
                    <textarea name="bio" id="bio" class="form-control" rows="2"
                        placeholder="e.g. CSE 3rd year | Competitive programmer | DSA enthusiast"
                        maxlength="300"></textarea>
                </div>
            </div>

            <!-- Submit -->
            <div class="auth-section" style="border-top:1px solid var(--border);">
                <button type="submit" class="btn btn-primary auth-submit">
                    <i class="fas fa-rocket"></i> Create Account & Join
                </button>
            </div>
        </form>
    </div>

    <div class="auth-alt">
        Already have an account? <a href="/login">Sign in here</a>
    </div>
</div>
</div>

<script>
function togglePass(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'fas fa-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'fas fa-eye';
    }
}

document.getElementById('branch').addEventListener('change', function() {
    const tip = document.getElementById('branch-tip');
    const tips = {
        'MBA': '📊 MBA: Share case studies, presentations, and business problems.',
        'CSE': '💻 CSE: Coding, DSA, projects, and placement challenges.',
        'ECE': '⚡ ECE: Circuits, signal processing, and embedded systems.',
        'IT': '🌐 IT: Networking, web dev, and IT management.',
        'Other': '🎓 All departments are welcome on Campus Connect!'
    };
    tip.textContent = tips[this.value] || 'All departments are welcome on Campus Connect.';
});
</script>