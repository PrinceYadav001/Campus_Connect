<% layout('/layouts/boilerplate') %>
<style>
    /* ── Hero ────────────────────────────────────────── */
    .home-hero {
        position: relative;
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        overflow: hidden;
        padding: 5rem 0;
    }

    .hero-bg-grid {
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgba(124,58,237,0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(124,58,237,0.04) 1px, transparent 1px);
        background-size: 48px 48px;
        pointer-events: none;
    }

    .hero-glow-1 {
        position: absolute;
        top: -10%;
        left: 20%;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(124,58,237,0.18) 0%, transparent 65%);
        pointer-events: none;
        animation: float 6s ease-in-out infinite;
    }

    .hero-glow-2 {
        position: absolute;
        bottom: -5%;
        right: 15%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(6,182,212,0.12) 0%, transparent 65%);
        pointer-events: none;
        animation: float 8s ease-in-out infinite reverse;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 820px;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(124,58,237,0.1);
        border: 1px solid rgba(124,58,237,0.3);
        border-radius: 50px;
        padding: 0.3rem 0.9rem;
        font-size: 0.75rem;
        font-weight: 700;
        color: #a78bfa;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 1.75rem;
    }

    .hero-badge::before { content: '✦'; font-size: 0.6rem; }

    .hero-h1 {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(2.6rem, 5.5vw, 4.6rem);
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -2.5px;
        color: var(--text);
        margin-bottom: 1.4rem;
    }

    .hero-h1 .grad {
        background: linear-gradient(135deg, #a78bfa 0%, #06b6d4 60%, #22c55e 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-sub {
        font-size: 1.15rem;
        color: var(--text-muted);
        max-width: 580px;
        line-height: 1.8;
        margin-bottom: 2.5rem;
    }

    .hero-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 3.5rem;
    }

    /* Stats */
    .hero-stats {
        display: flex;
        gap: 3rem;
        flex-wrap: wrap;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
    }

    .stat-item { display: flex; flex-direction: column; gap: 2px; }

    .stat-num {
        font-family: 'Outfit', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
        letter-spacing: -1px;
    }

    .stat-num span {
        background: linear-gradient(135deg, #a78bfa, #06b6d4);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .stat-lbl {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    /* ── Features section ────────────────────────────── */
    .features-section {
        padding: 6rem 0;
        border-top: 1px solid var(--border);
    }

    .features-eyebrow {
        text-align: center;
        margin-bottom: 0.75rem;
    }

    .features-title {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        font-weight: 800;
        text-align: center;
        color: var(--text);
        letter-spacing: -1px;
        margin-bottom: 0.85rem;
    }

    .features-sub {
        text-align: center;
        color: var(--text-muted);
        font-size: 1rem;
        margin-bottom: 3.5rem;
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    .feature-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: all 0.25s ease;
        position: relative;
        overflow: hidden;
    }

    .feature-card::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, var(--grad-from, rgba(124,58,237,0.06)) 0%, transparent 60%);
        pointer-events: none;
        transition: opacity 0.25s;
        opacity: 0;
    }

    .feature-card:hover::before { opacity: 1; }

    .feature-card:hover {
        border-color: var(--grad-border, rgba(124,58,237,0.3));
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(0,0,0,0.3);
    }

    .feature-card.card-purple { --grad-from: rgba(124,58,237,0.08); --grad-border: rgba(124,58,237,0.35); }
    .feature-card.card-cyan   { --grad-from: rgba(6,182,212,0.08); --grad-border: rgba(6,182,212,0.35); }
    .feature-card.card-green  { --grad-from: rgba(34,197,94,0.08); --grad-border: rgba(34,197,94,0.35); }
    .feature-card.card-amber  { --grad-from: rgba(245,158,11,0.08); --grad-border: rgba(245,158,11,0.35); }
    .feature-card.card-red    { --grad-from: rgba(239,68,68,0.08); --grad-border: rgba(239,68,68,0.35); }
    .feature-card.card-blue   { --grad-from: rgba(59,130,246,0.08); --grad-border: rgba(59,130,246,0.35); }

    .feature-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
    }

    .icon-purple { background: rgba(124,58,237,0.15); color: #a78bfa; }
    .icon-cyan   { background: rgba(6,182,212,0.12); color: #67e8f9; }
    .icon-green  { background: rgba(34,197,94,0.12); color: #86efac; }
    .icon-amber  { background: rgba(245,158,11,0.12); color: #fcd34d; }
    .icon-red    { background: rgba(239,68,68,0.12); color: #fca5a5; }
    .icon-blue   { background: rgba(59,130,246,0.12); color: #93c5fd; }

    .feature-title {
        font-family: 'Outfit', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
    }

    .feature-desc {
        font-size: 0.87rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    /* ── How it works ────────────────────────────────── */
    .how-section {
        padding: 6rem 0;
        border-top: 1px solid var(--border);
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        margin-top: 3.5rem;
    }

    .step-item {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }

    .step-num {
        font-family: 'Outfit', sans-serif;
        font-size: 3rem;
        font-weight: 900;
        line-height: 1;
        background: linear-gradient(135deg, #7c3aed, #06b6d4);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        opacity: 0.6;
    }

    .step-title {
        font-family: 'Outfit', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text);
    }

    .step-desc {
        font-size: 0.88rem;
        color: var(--text-muted);
        line-height: 1.7;
    }

    /* ── CTA section ─────────────────────────────────── */
    .cta-section {
        padding: 6rem 0;
        border-top: 1px solid var(--border);
    }

    .cta-card {
        background: var(--surface);
        border: 1px solid rgba(124,58,237,0.25);
        border-radius: 24px;
        padding: 4rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .cta-card::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 500px;
        height: 300px;
        background: radial-gradient(ellipse, rgba(124,58,237,0.15) 0%, transparent 70%);
        pointer-events: none;
    }

    .cta-h2 {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(1.8rem, 3vw, 2.8rem);
        font-weight: 900;
        color: var(--text);
        letter-spacing: -1px;
        margin-bottom: 1rem;
        position: relative;
    }

    .cta-sub {
        font-size: 1rem;
        color: var(--text-muted);
        margin-bottom: 2rem;
        position: relative;
    }

    .cta-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        position: relative;
    }

    /* Mobile responsive */
    @media (max-width: 900px) {
        .features-grid { grid-template-columns: repeat(2, 1fr); }
        .steps-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 600px) {
        .home-hero { padding: 3rem 0; min-height: auto; }
        .features-grid, .steps-grid { grid-template-columns: 1fr; }
        .hero-stats { gap: 1.5rem; }
        .cta-card { padding: 2.5rem 1.5rem; }
    }
</style>

<!-- Hero -->
<section class="home-hero">
    <div class="hero-bg-grid"></div>
    <div class="hero-glow-1"></div>
    <div class="hero-glow-2"></div>
    <div class="container">
        <div class="hero-content">
        <div class="hero-badge">
            <% if (currUser) { %>
                ✦ Welcome back, <%= currUser.username %>
            <% } else { %>
                ✦ Campus Connect &middot; Student Network
            <% } %>
        </div>
            <h1 class="hero-h1">
                Connect. Learn.<br>
                <span class="grad">Solve Together.</span>
            </h1>
            <p class="hero-sub">
                The peer-to-peer platform where campus students post academic problems, share solutions, earn recognition, and build a smarter community.
            </p>
            <div class="hero-actions">
                <% if (!currUser) { %>
                <a href="/signup" class="btn btn-primary btn-xl">
                    <i class="fas fa-rocket"></i> Join Campus Connect
                </a>
                <a href="/problems" class="btn btn-outline-primary btn-xl">
                    <i class="fas fa-layer-group"></i> Browse Problems
                </a>
                <% } else { %>
                <a href="/problems/new" class="btn btn-primary btn-xl">
                    <i class="fas fa-plus"></i> Post a Problem
                </a>
                <a href="/problems" class="btn btn-outline-primary btn-xl">
                    <i class="fas fa-layer-group"></i> Browse Problems
                </a>
                <% } %>
            </div>
            <div class="hero-stats">
                <div class="stat-item">
                    <div class="stat-num"><span><%= totalProblems %></span></div>
                    <div class="stat-lbl">Problems Posted</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num"><span><%= solvedProblems %></span></div>
                    <div class="stat-lbl">Solved</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num"><span><%= totalUsers %></span></div>
                    <div class="stat-lbl">Students</div>
                </div>
                <div class="stat-item">
                    <div class="stat-num"><span><%= totalSolutions %></span></div>
                    <div class="stat-lbl">Solutions Shared</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features -->
<section class="features-section">
    <div class="container">
        <div class="features-eyebrow">
            <span class="section-eyebrow"><i class="fas fa-sparkles"></i> Everything You Need</span>
        </div>
        <h2 class="features-title">Built for Campus Life</h2>
        <p class="features-sub">From homework to placement prep — Campus Connect has you covered across all departments.</p>

        <div class="features-grid">
            <div class="feature-card card-purple">
                <div class="feature-icon icon-purple"><i class="fas fa-paper-plane"></i></div>
                <div class="feature-title">Post Any Problem</div>
                <div class="feature-desc">Share homework doubts, project blockers, exam prep questions, or placement challenges. Categorize by branch and difficulty.</div>
            </div>
            <div class="feature-card card-cyan">
                <div class="feature-icon icon-cyan"><i class="fas fa-comments"></i></div>
                <div class="feature-title">Get Real Solutions</div>
                <div class="feature-desc">Peers provide detailed answers. Vote on the best responses. Accept a solution to mark your problem as solved.</div>
            </div>
            <div class="feature-card card-green">
                <div class="feature-icon icon-green"><i class="fas fa-trophy"></i></div>
                <div class="feature-title">Earn Recognition</div>
                <div class="feature-desc">Get upvotes for helpful answers. Climb the leaderboard. Your contributions build your campus reputation.</div>
            </div>
            <div class="feature-card card-amber">
                <div class="feature-icon icon-amber"><i class="fas fa-users"></i></div>
                <div class="feature-title">Connect with Peers</div>
                <div class="feature-desc">Discover students across CSE, ECE, IT, MBA. View profiles, see their skills, and build your network.</div>
            </div>
            <div class="feature-card card-red">
                <div class="feature-icon icon-red"><i class="fas fa-filter"></i></div>
                <div class="feature-title">Smart Filtering</div>
                <div class="feature-desc">Filter problems by branch, type (Exam, Project, Placement), difficulty, or search by keyword instantly.</div>
            </div>
            <div class="feature-card card-blue">
                <div class="feature-icon icon-blue"><i class="fas fa-image"></i></div>
                <div class="feature-title">Rich Problem Posts</div>
                <div class="feature-desc">Attach images to your problems for circuits, code screenshots, diagrams, or visual questions.</div>
            </div>
        </div>
    </div>
</section>

<!-- How it works -->
<section class="how-section">
    <div class="container">
        <div class="features-eyebrow" style="text-align:center;">
            <span class="section-eyebrow"><i class="fas fa-map"></i> Simple & Effective</span>
        </div>
        <h2 class="features-title">How Campus Connect Works</h2>

        <div class="steps-grid">
            <div class="step-item">
                <div class="step-num">01</div>
                <div class="step-title">Create Your Profile</div>
                <div class="step-desc">Sign up free. Add your branch, year, skills, and social links. Join the community in under a minute.</div>
            </div>
            <div class="step-item">
                <div class="step-num">02</div>
                <div class="step-title">Post Your Problem</div>
                <div class="step-desc">Describe your challenge. Add tags, choose difficulty, and optionally attach an image. Your post goes live instantly.</div>
            </div>
            <div class="step-item">
                <div class="step-num">03</div>
                <div class="step-title">Get Community Help</div>
                <div class="step-desc">Fellow students answer your problem. You can accept the best solution, upvote helpful answers, and mark it solved.</div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="cta-section">
    <div class="container">
        <div class="cta-card">
            <h2 class="cta-h2">Ready to Connect?</h2>
            <p class="cta-sub">Join hundreds of students already solving problems together on Campus Connect.</p>
            <div class="cta-actions">
                <% if (!currUser) { %>
                <a href="/signup" class="btn btn-primary btn-xl">
                    <i class="fas fa-user-plus"></i> Create Free Account
                </a>
                <a href="/problems" class="btn btn-secondary btn-lg">
                    <i class="fas fa-eye"></i> Browse Problems First
                </a>
                <% } else { %>
                <a href="/problems/new" class="btn btn-primary btn-xl">
                    <i class="fas fa-plus"></i> Post a Problem
                </a>
                <a href="/leaderboard" class="btn btn-secondary btn-lg">
                    <i class="fas fa-trophy"></i> View Leaderboard
                </a>
                <% } %>
            </div>
        </div>
    </div>
</section>
