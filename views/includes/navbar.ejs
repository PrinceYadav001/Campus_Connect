<%# ── Campus Connect Navbar ──────────────────────── %>
<style>
    .cc-nav {
        position: sticky;
        top: 0;
        z-index: 1000;
        background: rgba(5, 8, 22, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(124, 58, 237, 0.15);
        width: 100%;
    }

    .cc-nav-inner {
        display: flex;
        align-items: center;
        height: 60px;
        gap: 0;
    }

    /* Logo */
    .cc-logo {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        text-decoration: none;
        flex-shrink: 0;
        padding-right: 1.25rem;
    }

    .cc-logo-mark {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #7c3aed, #06b6d4);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 0 16px rgba(124,58,237,0.4);
    }

    .cc-logo-text {
        display: flex;
        flex-direction: column;
        line-height: 1.1;
    }

    .cc-logo-name {
        font-family: 'Outfit', sans-serif;
        font-size: 1rem;
        font-weight: 800;
        color: #e6edf3;
        letter-spacing: -0.3px;
    }

    .cc-logo-name span {
        background: linear-gradient(135deg, #a78bfa, #67e8f9);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .cc-logo-sub {
        font-size: 0.6rem;
        color: #484f58;
        letter-spacing: 0.3px;
    }

    /* Separator */
    .cc-sep {
        width: 1px;
        height: 22px;
        background: rgba(124,58,237,0.2);
        flex-shrink: 0;
        margin-right: 1rem;
    }

    /* Nav links */
    .cc-links {
        display: flex;
        align-items: center;
        gap: 2px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .cc-link {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.38rem 0.75rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 500;
        color: #8b949e;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.18s;
        cursor: pointer;
        border: none;
        background: transparent;
        font-family: inherit;
    }

    .cc-link:hover,
    .cc-link.active {
        background: rgba(124,58,237,0.1);
        color: #a78bfa;
    }

    .cc-link i { font-size: 0.75rem; }

    /* CTA button */
    .cc-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.38rem 0.9rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        background: var(--primary, #7c3aed);
        color: #fff !important;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.18s;
        border: none;
        cursor: pointer;
        box-shadow: 0 0 16px rgba(124,58,237,0.35);
    }

    .cc-cta:hover {
        background: #5b21b6;
        color: #fff !important;
        box-shadow: 0 0 24px rgba(124,58,237,0.55);
        transform: translateY(-1px);
    }

    .cc-cta i { font-size: 0.75rem; }

    /* Spacer */
    .cc-spacer { flex: 1; }

    /* Right side */
    .cc-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-shrink: 0;
    }

    /* User chip */
    .cc-user-chip {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.22rem 0.7rem 0.22rem 0.22rem;
        border: 1px solid rgba(124,58,237,0.2);
        border-radius: 8px;
        background: rgba(124,58,237,0.06);
        text-decoration: none;
        transition: all 0.18s;
    }

    .cc-user-chip:hover {
        border-color: rgba(124,58,237,0.4);
        background: rgba(124,58,237,0.1);
    }

    .cc-avatar {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        background: linear-gradient(135deg, #7c3aed, #06b6d4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .cc-uname {
        font-size: 0.82rem;
        font-weight: 600;
        color: #e6edf3;
        line-height: 1;
    }

    .cc-ubranch {
        font-size: 0.62rem;
        color: #484f58;
        line-height: 1;
    }

    .cc-logout {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.35rem 0.7rem;
        border-radius: 8px;
        font-size: 0.825rem;
        font-weight: 500;
        color: #8b949e;
        text-decoration: none;
        border: 1px solid transparent;
        transition: all 0.18s;
        white-space: nowrap;
    }

    .cc-logout:hover {
        color: #ef4444;
        background: rgba(239,68,68,0.08);
        border-color: rgba(239,68,68,0.2);
    }

    /* Hamburger */
    .cc-hamburger {
        display: none;
        flex-direction: column;
        gap: 4px;
        cursor: pointer;
        padding: 7px 8px;
        border: 1px solid rgba(124,58,237,0.2);
        border-radius: 8px;
        background: transparent;
        flex-shrink: 0;
    }

    .cc-hamburger span {
        width: 16px;
        height: 2px;
        background: #8b949e;
        border-radius: 2px;
        display: block;
    }

    /* Mobile */
    @media (max-width: 768px) {
        .cc-hamburger { display: flex; }
        .cc-sep { display: none; }

        .cc-desktop {
            display: none;
            position: absolute;
            top: 61px;
            left: 0;
            right: 0;
            background: rgba(5,8,22,0.97);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(124,58,237,0.2);
            padding: 0.75rem 1rem;
            flex-direction: column;
            align-items: flex-start;
            gap: 0.25rem;
            z-index: 999;
        }

        .cc-desktop.open { display: flex; }
        .cc-links { flex-direction: column; align-items: flex-start; width: 100%; }
        .cc-link, .cc-cta { width: 100%; }
        .cc-right { flex-direction: column; align-items: flex-start; width: 100%; gap: 0.25rem; }
        .cc-user-chip { width: 100%; }
        .cc-logout { width: 100%; }
        .cc-spacer { display: none; }
    }

    @media (min-width: 769px) {
        .cc-desktop {
            display: flex;
            align-items: center;
            flex: 1;
            gap: 0;
        }
    }
</style>

<nav class="cc-nav" role="navigation" aria-label="Main navigation">
    <div class="container">
        <div class="cc-nav-inner">

            <!-- Logo -->
            <a class="cc-logo" href="/" aria-label="Campus Connect Home">
                <div class="cc-logo-mark">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2L2 7l10 5 10-5-10-5z" fill="white" opacity="0.9"/>
                        <path d="M2 17l10 5 10-5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none" opacity="0.7"/>
                        <path d="M2 12l10 5 10-5" stroke="white" stroke-width="1.8" stroke-linecap="round" fill="none"/>
                    </svg>
                </div>
                <div class="cc-logo-text">
                    <span class="cc-logo-name">Campus<span>Connect</span></span>
                    <span class="cc-logo-sub">Student Problem Network</span>
                </div>
            </a>

            <div class="cc-sep" aria-hidden="true"></div>

            <!-- Mobile hamburger -->
            <button class="cc-hamburger" id="cc-nav-toggle" aria-label="Menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>

            <!-- Desktop / collapsible -->
            <div class="cc-desktop" id="cc-nav-desktop">

                <ul class="cc-links">
                    <li>
                        <a class="cc-link" href="/problems" id="nav-problems">
                            <i class="fas fa-layer-group"></i> Problems
                        </a>
                    </li>
                    <li>
                        <a class="cc-link" href="/leaderboard" id="nav-leaderboard">
                            <i class="fas fa-trophy"></i> Leaderboard
                        </a>
                    </li>
                    <li>
                        <a class="cc-cta" href="/problems/new">
                            <i class="fas fa-plus"></i> Post Problem
                        </a>
                    </li>
                </ul>

                <div class="cc-spacer"></div>

                <div class="cc-right">
                    <% if (!currUser) { %>
                        <a class="cc-link" href="/login">Log in</a>
                        <a class="cc-cta" href="/signup">Sign up free</a>
                    <% } else { %>
                        <a class="cc-user-chip" href="/users/<%= currUser.username %>">
                            <div class="cc-avatar"><%= currUser.username.charAt(0).toUpperCase() %></div>
                            <div>
                                <div class="cc-uname"><%= currUser.username %></div>
                                <div class="cc-ubranch"><%= currUser.branch || 'Student' %></div>
                            </div>
                        </a>
                        <a class="cc-logout" href="/logout">
                            <i class="fas fa-sign-out-alt"></i> Log out
                        </a>
                    <% } %>
                </div>

            </div>
        </div>
    </div>
</nav>

<script>
    (function() {
        const toggle = document.getElementById('cc-nav-toggle');
        const desktop = document.getElementById('cc-nav-desktop');
        if (!toggle || !desktop) return;
        toggle.addEventListener('click', function() {
            const open = desktop.classList.toggle('open');
            this.setAttribute('aria-expanded', open);
        });
    })();

    (function() {
        const path = window.location.pathname;
        const links = {
            'nav-problems':    path.startsWith('/problems'),
            'nav-leaderboard': path.startsWith('/leaderboard'),
        };
        for (const [id, active] of Object.entries(links)) {
            if (active) document.getElementById(id)?.classList.add('active');
        }
    })();
</script>