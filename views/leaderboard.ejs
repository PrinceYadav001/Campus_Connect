<% layout('/layouts/boilerplate') %>
<style>
    .lb-hero {
        padding: 3.5rem 0 2.5rem;
        border-bottom: 1px solid var(--border);
    }

    .lb-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--amber);
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 0.75rem;
        border: 1px solid var(--amber-border);
        padding: 0.2rem 0.75rem;
        border-radius: 50px;
    }

    .lb-h1 {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 900;
        letter-spacing: -1px;
        color: var(--text);
        margin-bottom: 0.6rem;
    }

    .lb-sub {
        font-size: 0.95rem;
        color: var(--text-muted);
        max-width: 500px;
    }

    /* Podium top 3 */
    .podium-section {
        padding: 3rem 0 2rem;
        border-bottom: 1px solid var(--border);
    }

    .podium-grid {
        display: flex;
        align-items: flex-end;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .podium-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.85rem;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.75rem 2rem;
        min-width: 200px;
        text-align: center;
        transition: transform 0.25s, box-shadow 0.25s;
        position: relative;
    }

    .podium-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(0,0,0,0.35);
    }

    .podium-card.rank-1 {
        border-color: rgba(245,158,11,0.4);
        background: linear-gradient(160deg, rgba(245,158,11,0.06) 0%, var(--surface) 50%);
        order: 2;
        padding-top: 2.25rem;
    }

    .podium-card.rank-2 {
        border-color: rgba(148,163,184,0.3);
        order: 1;
    }

    .podium-card.rank-3 {
        border-color: rgba(205,127,50,0.3);
        order: 3;
    }

    .podium-crown {
        font-size: 1.5rem;
        position: absolute;
        top: -16px;
    }

    .podium-rank-badge {
        position: absolute;
        top: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 800;
        border: 2px solid var(--bg);
    }

    .rank-1 .podium-rank-badge { background: #f59e0b; color: #000; }
    .rank-2 .podium-rank-badge { background: #94a3b8; color: #000; }
    .rank-3 .podium-rank-badge { background: #cd7f32; color: #fff; }

    .podium-avatar {
        width: 64px;
        height: 64px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Outfit', sans-serif;
        font-size: 1.6rem;
        font-weight: 800;
        color: #fff;
    }

    .rank-1 .podium-avatar { width: 72px; height: 72px; font-size: 1.8rem; box-shadow: 0 0 24px rgba(245,158,11,0.35); }

    .podium-name {
        font-family: 'Outfit', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text);
    }

    .podium-branch {
        font-size: 0.75rem;
        color: var(--text-dim);
    }

    .podium-score {
        font-family: 'Outfit', sans-serif;
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--text);
    }

    .podium-score span { font-size: 0.72rem; font-weight: 400; color: var(--text-dim); font-family: var(--font); }

    .podium-stats {
        display: flex;
        gap: 1rem;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .ps-item { display: flex; align-items: center; gap: 0.3rem; }

    /* ── Main leaderboard table ──────────────────────── */
    .lb-section {
        padding: 2.5rem 0 4rem;
    }

    .lb-table-wrap {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
    }

    .lb-table-head {
        display: grid;
        grid-template-columns: 60px 1fr 80px 80px 80px 80px;
        gap: 0;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-dim);
        padding: 0.9rem 1.5rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface-2);
    }

    .lb-row {
        display: grid;
        grid-template-columns: 60px 1fr 80px 80px 80px 80px;
        gap: 0;
        padding: 0.9rem 1.5rem;
        border-bottom: 1px solid var(--border);
        align-items: center;
        transition: background 0.15s;
    }

    .lb-row:last-child { border-bottom: none; }

    .lb-row:hover { background: var(--surface-2); }

    .lb-row.top-row { background: rgba(245,158,11,0.04); }

    .lb-rank {
        font-family: 'Outfit', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-dim);
    }

    .lb-rank.r1 { color: #f59e0b; }
    .lb-rank.r2 { color: #94a3b8; }
    .lb-rank.r3 { color: #cd7f32; }

    .lb-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .lb-avatar {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.9rem;
        color: #fff;
        flex-shrink: 0;
    }

    .lb-uname {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text);
    }

    .lb-ubranch {
        font-size: 0.72rem;
        color: var(--text-dim);
    }

    .lb-cell {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--text-muted);
        text-align: center;
    }

    .lb-score-cell {
        font-family: 'Outfit', sans-serif;
        font-size: 1rem;
        font-weight: 800;
        color: var(--text);
        text-align: center;
    }

    .empty-lb {
        text-align: center;
        padding: 5rem 2rem;
        color: var(--text-muted);
    }

    .empty-lb-icon { font-size: 3rem; margin-bottom: 1rem; opacity: 0.3; }

    @media (max-width: 768px) {
        .lb-table-head,
        .lb-row {
            grid-template-columns: 46px 1fr 60px 60px;
        }
        .lb-table-head span:nth-child(4),
        .lb-table-head span:nth-child(5),
        .lb-row .lb-cell:nth-child(4),
        .lb-row .lb-cell:nth-child(5) { display: none; }
        .podium-grid { gap: 0.75rem; }
        .podium-card { min-width: 140px; padding: 1.25rem 1rem; }
    }
</style>

<!-- Hero -->
<section class="lb-hero">
    <div class="container">
        <div class="lb-eyebrow">🏆 Campus Leaderboard</div>
        <h1 class="lb-h1">Top Campus Contributors</h1>
        <p class="lb-sub">Students ranked by their community impact — problems posted, solutions shared, and upvotes earned.</p>
    </div>
</section>

<% if (leaderData.length >= 3) { %>
<!-- Podium Top 3 -->
<section class="podium-section">
    <div class="container">
        <div class="podium-grid">
            <% const top3 = leaderData.slice(0, 3); %>
            <% const displayOrder = [top3[1], top3[0], top3[2]].filter(Boolean); %>
            <% const rankClass = { 0: 'rank-2', 1: 'rank-1', 2: 'rank-3' }; %>
            <% const rankNum = { 0: 2, 1: 1, 2: 3 }; %>
            <% displayOrder.forEach((entry, i) => { %>
                <div class="podium-card <%= rankClass[i] %>">
                    <% if (rankNum[i] === 1) { %><div class="podium-crown">👑</div><% } %>
                    <div class="podium-rank-badge"><%= rankNum[i] %></div>
                    <div class="podium-avatar" style="background: <%= entry.user.avatarColor || '#7c3aed' %>;">
                        <%= entry.user.username.charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <div class="podium-name"><a href="/users/<%= entry.user.username %>" style="color:inherit;"><%= entry.user.username %></a></div>
                        <div class="podium-branch"><%= entry.user.branch || 'Student' %> · Year <%= entry.user.year || 1 %></div>
                    </div>
                    <div class="podium-score"><%= entry.score %> <span>pts</span></div>
                    <div class="podium-stats">
                        <span class="ps-item"><i class="fas fa-layer-group" style="color:var(--primary-light)"></i> <%= entry.problemsPosted %></span>
                        <span class="ps-item"><i class="fas fa-comment-dots" style="color:var(--accent)"></i> <%= entry.solutionsGiven %></span>
                        <span class="ps-item"><i class="fas fa-arrow-up" style="color:var(--green)"></i> <%= entry.upvotesReceived %></span>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>
<% } %>

<!-- Full table -->
<section class="lb-section">
    <div class="container">
        <% if (leaderData.length === 0) { %>
            <div class="lb-table-wrap">
                <div class="empty-lb">
                    <div class="empty-lb-icon"><i class="fas fa-trophy"></i></div>
                    <h3 style="color:var(--text);margin-bottom:0.5rem;">Leaderboard is empty</h3>
                    <p>Be the first to post problems and share solutions to appear here!</p>
                    <a href="/signup" class="btn btn-primary" style="margin-top:1.25rem;"><i class="fas fa-rocket"></i> Get Started</a>
                </div>
            </div>
        <% } else { %>
            <div class="lb-table-wrap">
                <div class="lb-table-head">
                    <span># Rank</span>
                    <span>Student</span>
                    <span style="text-align:center;">Problems</span>
                    <span style="text-align:center;">Solutions</span>
                    <span style="text-align:center;">Upvotes</span>
                    <span style="text-align:center;">Score</span>
                </div>
                <% leaderData.forEach((entry, idx) => { %>
                    <div class="lb-row <%= idx === 0 ? 'top-row' : '' %>">
                        <span class="lb-rank <%= idx === 0 ? 'r1' : idx === 1 ? 'r2' : idx === 2 ? 'r3' : '' %>">
                            <% if (idx === 0) { %>🥇<% } else if (idx === 1) { %>🥈<% } else if (idx === 2) { %>🥉<% } else { %><%= idx + 1 %><% } %>
                        </span>
                        <div class="lb-user">
                            <div class="lb-avatar" style="background: <%= entry.user.avatarColor || '#7c3aed' %>;">
                                <%= entry.user.username.charAt(0).toUpperCase() %>
                            </div>
                            <div>
                                <div class="lb-uname"><a href="/users/<%= entry.user.username %>" style="color:inherit;text-decoration:none;"><%= entry.user.username %></a></div>
                                <div class="lb-ubranch"><%= entry.user.branch || 'Student' %> · Yr <%= entry.user.year || 1 %></div>
                            </div>
                        </div>
                        <div class="lb-cell"><i class="fas fa-layer-group" style="color:var(--primary-light);margin-right:4px;font-size:0.72rem;"></i><%= entry.problemsPosted %></div>
                        <div class="lb-cell"><i class="fas fa-comment-dots" style="color:var(--accent);margin-right:4px;font-size:0.72rem;"></i><%= entry.solutionsGiven %></div>
                        <div class="lb-cell"><i class="fas fa-arrow-up" style="color:var(--green);margin-right:4px;font-size:0.72rem;"></i><%= entry.upvotesReceived %></div>
                        <div class="lb-score-cell"><%= entry.score %></div>
                    </div>
                <% }) %>
            </div>
            <p style="font-size:0.72rem;color:var(--text-dim);margin-top:0.75rem;text-align:right;">Score = (Problems × 2) + (Solutions × 3) + (Upvotes × 1)</p>
        <% } %>
    </div>
</section>
