<% layout('/layouts/boilerplate') %>
<style>
    /* ── Hero ────────────────────────────────────── */
    .hero {
        padding: 3.5rem 0 2.5rem;
        border-bottom: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -5%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(124,58,237,0.09) 0%, transparent 65%);
        pointer-events: none;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--primary-light);
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 1rem;
        border: 1px solid var(--primary-border);
        padding: 0.22rem 0.8rem;
        border-radius: 50px;
        width: fit-content;
    }

    .hero h1 {
        font-family: 'Outfit', sans-serif;
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -1.2px;
        color: var(--text);
        margin-bottom: 0.85rem;
        max-width: 680px;
    }

    .hero h1 em {
        font-style: normal;
        background: linear-gradient(135deg, #a78bfa, #06b6d4);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .hero-sub {
        font-size: 0.98rem;
        color: var(--text-muted);
        max-width: 520px;
        line-height: 1.75;
        margin-bottom: 1.75rem;
    }

    .hero-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .hero-motto {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
        color: var(--text-dim);
        font-size: 0.82rem;
    }

    .motto-item {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .motto-item i { color: var(--primary-light); font-size: 0.85rem; }
    .motto-sep { color: var(--border-hover); font-weight: 700; }

    /* Stats */
    .hero-stats {
        display: flex;
        gap: 2.5rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .stat-item { display: flex; flex-direction: column; gap: 2px; }

    .stat-num {
        font-family: 'Outfit', sans-serif;
        font-size: 1.7rem;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
        letter-spacing: -0.5px;
    }

    .stat-lbl { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }

    /* ── Toolbar ─────────────────────────────────── */
    .toolbar {
        padding: 1.5rem 0 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .filter-tabs {
        display: flex;
        gap: 0.3rem;
        flex-wrap: wrap;
    }

    .filter-tab {
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        font-size: 0.82rem;
        font-weight: 500;
        color: var(--text-muted);
        background: transparent;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.18s;
        user-select: none;
    }

    .filter-tab:hover {
        background: var(--surface-2);
        color: var(--text);
    }

    .filter-tab.active {
        background: var(--primary-bg);
        border-color: var(--primary-border);
        color: var(--primary-light);
    }

    .search-box {
        display: flex;
        align-items: center;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.18s;
        min-width: 220px;
    }

    .search-box:focus-within { border-color: var(--primary); box-shadow: 0 0 0 3px var(--primary-glow); }

    .search-box input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        padding: 0.45rem 0.75rem;
        color: var(--text);
        font-size: 0.85rem;
        font-family: var(--font);
        min-width: 0;
    }

    .search-box input::placeholder { color: var(--text-dim); }
    .search-icon { padding: 0 0.7rem; color: var(--text-dim); font-size: 0.8rem; }

    /* ── Section header ── */
    .section-row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 1.5rem 0 1rem;
        gap: 1rem;
    }

    .section-title { font-size: 0.95rem; font-weight: 600; color: var(--text); }
    .results-label { font-size: 0.82rem; color: var(--text-dim); }

    /* ── Problem card grid ─────────────────────── */
    .problems-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 3rem;
    }

    .p-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.1rem 1.2rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
        position: relative;
        overflow: hidden;
    }

    .p-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: var(--accent-bar, var(--border));
        transition: background 0.2s;
    }

    .p-card[data-diff="easy"]::before   { --accent-bar: var(--green); }
    .p-card[data-diff="medium"]::before { --accent-bar: var(--amber); }
    .p-card[data-diff="hard"]::before   { --accent-bar: var(--red); }

    .p-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.4);
        border-color: rgba(124,58,237,0.25);
    }

    .p-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .p-card-badges { display: flex; gap: 0.3rem; flex-wrap: wrap; }

    .p-diff {
        font-size: 0.68rem;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        border: 1px solid transparent;
        flex-shrink: 0;
    }

    .diff-easy   { background: var(--green-bg); color: var(--green); border-color: var(--green-border); }
    .diff-medium { background: var(--amber-bg); color: var(--amber); border-color: var(--amber-border); }
    .diff-hard   { background: var(--red-bg);   color: var(--red);   border-color: var(--red-border); }

    .p-card-img {
        width: 100%;
        height: 140px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid var(--border);
        display: block;
    }

    .p-card-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .p-card-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .p-card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem;
        margin-top: 0.1rem;
    }

    .p-tag {
        font-size: 0.67rem;
        padding: 1px 7px;
        border-radius: 4px;
        background: var(--primary-bg);
        border: 1px solid var(--primary-border);
        color: var(--primary-light);
        font-family: monospace;
        letter-spacing: 0.2px;
    }

    .p-card-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--text-dim);
        border-top: 1px solid var(--border);
        padding-top: 0.65rem;
        margin-top: auto;
        gap: 0.4rem;
    }

    .p-author {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        min-width: 0;
    }

    .p-avatar {
        width: 22px;
        height: 22px;
        border-radius: 5px;
        background: linear-gradient(135deg, #7c3aed, #06b6d4);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.63rem;
        font-weight: 800;
        color: #fff;
        flex-shrink: 0;
    }

    .p-author-name {
        font-size: 0.75rem;
        color: var(--text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .p-foot-right {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-shrink: 0;
    }

    .p-sol-count {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        font-size: 0.72rem;
        color: var(--text-dim);
    }

    .p-status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .dot-open   { background: var(--primary-light); }
    .dot-solved { background: var(--green); }

    .p-status-text {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .p-card-link { position: absolute; inset: 0; }

    /* Empty state */
    .empty-state {
        grid-column: 1 / -1;
        text-align: center;
        padding: 5rem 2rem;
        background: var(--surface);
        border: 1px dashed rgba(124,58,237,0.25);
        border-radius: 14px;
        color: var(--text-muted);
    }

    .empty-icon { font-size: 2.5rem; margin-bottom: 1rem; opacity: 0.3; }
    .empty-state h3 { font-size: 1.1rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; }
    .empty-state p { font-size: 0.88rem; margin-bottom: 1.5rem; }

    /* Responsive */
    @media (max-width: 900px) { .problems-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 768px) {
        .hero { padding: 2.5rem 0 2rem; }
        .hero-stats { gap: 1.5rem; }
        .toolbar { flex-direction: column; align-items: flex-start; }
        .search-box { width: 100%; }
    }
    @media (max-width: 576px) {
        .problems-grid { grid-template-columns: 1fr; }
        .filter-tabs { gap: 2px; }
        .filter-tab { font-size: 0.78rem; padding: 0.25rem 0.55rem; }
    }
</style>

<!-- Hero -->
<section class="hero">
    <div class="container">
        <div class="hero-eyebrow"><i class="fas fa-graduation-cap"></i> Campus Connect · Problem Board</div>
        <h1>Think. <em>Solve.</em> Connect.</h1>
        <p class="hero-sub">Post your academic challenge, get solutions from peers. Every problem solved is a step towards mastery.</p>

        <div class="hero-actions">
            <a href="/problems/new" class="btn btn-primary btn-lg">
                <i class="fas fa-plus"></i> Post a Problem
            </a>
            <a href="#problems" class="btn btn-outline-primary btn-lg">
                <i class="fas fa-layer-group"></i> Browse Problems
            </a>
        </div>

        <div class="hero-motto">
            <span class="motto-item"><i class="fas fa-lightbulb"></i> Every problem is a chance to grow</span>
            <span class="motto-sep">·</span>
            <span class="motto-item"><i class="fas fa-users"></i> Peers helping peers</span>
            <span class="motto-sep">·</span>
            <span class="motto-item"><i class="fas fa-rocket"></i> Build. Solve. Connect.</span>
        </div>

        <div class="hero-stats">
            <div class="stat-item">
                <div class="stat-num"><%= problems.length %></div>
                <div class="stat-lbl">Total Problems</div>
            </div>
            <div class="stat-item">
                <div class="stat-num"><%= problems.filter(p => p.status === 'solved').length %></div>
                <div class="stat-lbl">Solved</div>
            </div>
            <div class="stat-item">
                <div class="stat-num"><%= problems.filter(p => p.status === 'open').length %></div>
                <div class="stat-lbl">Open</div>
            </div>
            <div class="stat-item">
                <div class="stat-num"><%= new Set(problems.map(p => p.author.username)).size %></div>
                <div class="stat-lbl">Contributors</div>
            </div>
        </div>
    </div>
</section>

<!-- Filter + Search toolbar -->
<div class="container" id="problems">
    <div class="toolbar">
        <div class="filter-tabs" id="filter-bar">
            <button class="filter-tab active" data-filter="all">All</button>
            <button class="filter-tab" data-filter="CSE">CSE</button>
            <button class="filter-tab" data-filter="ECE">ECE</button>
            <button class="filter-tab" data-filter="IT">IT</button>
            <button class="filter-tab" data-filter="MBA">MBA</button>
            <button class="filter-tab" data-filter="Homework">Homework</button>
            <button class="filter-tab" data-filter="Project">Project</button>
            <button class="filter-tab" data-filter="Exam">Exam</button>
            <button class="filter-tab" data-filter="Placement">Placement</button>
            <button class="filter-tab" data-filter="Campus">Campus</button>
        </div>

        <div class="search-box">
            <i class="fas fa-search search-icon"></i>
            <input type="search" id="search-input" placeholder="Search problems…" autocomplete="off">
        </div>
    </div>

    <div class="section-row">
        <span class="section-title"><span id="active-filter-label">All</span> Problems</span>
        <span class="results-label" id="results-count"><%= problems.length %> result<%= problems.length !== 1 ? 's' : '' %></span>
    </div>

    <!-- Cards grid -->
    <div class="problems-grid" id="problems-container">
        <% if (problems.length === 0) { %>
            <div class="empty-state">
                <div class="empty-icon"><i class="fas fa-inbox"></i></div>
                <h3>Nothing here yet</h3>
                <p>Be the first to post a problem and get help from the Campus Connect community.</p>
                <a href="/problems/new" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Post First Problem
                </a>
            </div>
        <% } else { %>
            <% for(let problem of problems) { %>
                <div class="p-card problem-item"
                     data-category="<%= problem.category %>"
                     data-type="<%= problem.type %>"
                     data-diff="<%= problem.difficulty %>">

                    <div class="p-card-top">
                        <div class="p-card-badges">
                            <span class="badge badge-primary"><%= problem.category %></span>
                            <span class="badge badge-muted"><%= problem.type %></span>
                        </div>
                        <span class="p-diff diff-<%= problem.difficulty %>"><%= problem.difficulty %></span>
                    </div>

                    <% if (problem.image && problem.image.url) { %>
                        <img src="<%= problem.image.url %>"
                             class="p-card-img"
                             alt="<%= problem.title %>"
                             loading="lazy"
                             onerror="this.style.display='none'">
                    <% } %>

                    <div class="p-card-title"><%= problem.title %></div>
                    <div class="p-card-desc"><%= problem.description %></div>

                    <% if (problem.tags && problem.tags.length > 0) { %>
                        <div class="p-card-tags">
                            <% for(let tag of problem.tags.slice(0,4)) { %>
                                <% if(tag && tag.trim()) { %>
                                    <span class="p-tag">#<%= tag.trim() %></span>
                                <% } %>
                            <% } %>
                        </div>
                    <% } %>

                    <div class="p-card-foot">
                        <div class="p-author">
                            <div class="p-avatar"><%= problem.author.username.charAt(0).toUpperCase() %></div>
                            <span class="p-author-name"><%= problem.author.username %></span>
                        </div>
                        <div class="p-foot-right">
                            <% if (problem.solutions && problem.solutions.length > 0) { %>
                                <span class="p-sol-count">
                                    <i class="fas fa-comment-dots"></i>
                                    <%= problem.solutions.length %>
                                </span>
                            <% } %>
                            <div style="display:flex;align-items:center;gap:0.3rem;">
                                <span class="p-status-dot <%= problem.status === 'solved' ? 'dot-solved' : 'dot-open' %>"></span>
                                <span class="p-status-text" style="color:<%= problem.status === 'solved' ? 'var(--green)' : 'var(--primary-light)' %>">
                                    <%= problem.status %>
                                </span>
                            </div>
                        </div>
                    </div>

                    <a href="/problems/<%= problem._id %>" class="p-card-link" aria-label="View <%= problem.title %>"></a>
                </div>
            <% } %>
        <% } %>
    </div>
</div>

<script>
    const filterTabs  = document.querySelectorAll('.filter-tab');
    const items       = document.querySelectorAll('.problem-item');
    const countEl     = document.getElementById('results-count');
    const labelEl     = document.getElementById('active-filter-label');
    const searchInput = document.getElementById('search-input');

    let activeFilter = 'all';
    let searchQuery  = '';

    function applyFilters() {
        let visible = 0;
        items.forEach(item => {
            const cat  = item.dataset.category || '';
            const type = item.dataset.type || '';
            const title = item.querySelector('.p-card-title')?.textContent.toLowerCase() || '';
            const desc  = item.querySelector('.p-card-desc')?.textContent.toLowerCase()  || '';

            const matchFilter = activeFilter === 'all' || cat === activeFilter || type === activeFilter;
            const matchSearch = !searchQuery || title.includes(searchQuery) || desc.includes(searchQuery) || cat.toLowerCase().includes(searchQuery) || type.toLowerCase().includes(searchQuery);

            const show = matchFilter && matchSearch;
            item.style.display = show ? '' : 'none';
            if (show) visible++;
        });

        const label = activeFilter === 'all' ? 'All' : activeFilter;
        labelEl.textContent = label;
        countEl.textContent = `${visible} result${visible !== 1 ? 's' : ''}`;
    }

    filterTabs.forEach(tab => {
        tab.addEventListener('click', function() {
            filterTabs.forEach(t => t.classList.remove('active'));
            this.classList.add('active');
            activeFilter = this.dataset.filter;
            applyFilters();
        });
    });

    let debounce;
    searchInput.addEventListener('input', function() {
        clearTimeout(debounce);
        debounce = setTimeout(() => {
            searchQuery = this.value.trim().toLowerCase();
            applyFilters();
        }, 200);
    });
</script>